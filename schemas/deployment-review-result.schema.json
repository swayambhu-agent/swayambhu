{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_role",
    "verdict",
    "confidence",
    "summary",
    "target_current_version",
    "expected_predecessor_version",
    "causal_adjacency",
    "evidence_for_improvement",
    "evidence_for_regression",
    "quarantine_recommended",
    "quarantine_reason"
  ],
  "properties": {
    "review_role": {
      "type": "string",
      "const": "deployment_review"
    },
    "verdict": {
      "type": "string",
      "enum": ["keep", "rollback", "extend"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "target_current_version": {
      "type": "string",
      "minLength": 1
    },
    "expected_predecessor_version": {
      "type": ["string", "null"]
    },
    "causal_adjacency": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidence_for_improvement": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_for_regression": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quarantine_recommended": {
      "type": "boolean"
    },
    "quarantine_reason": {
      "type": ["string", "null"]
    }
  }
}
