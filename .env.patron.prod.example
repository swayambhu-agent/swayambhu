ACCESS_EMAILS=swami.kevala@gmail.com
CF_ACCESS_AUTH_DOMAIN=

# Optional naming overrides
SITE_PROJECT=swayambhu-site
RUNTIME_NAME=swayambhu-cns
DASHBOARD_NAME=swayambhu-dashboard-api
KV_TITLE=swayambhu-prod-kv
WORKERS_SUBDOMAIN=
