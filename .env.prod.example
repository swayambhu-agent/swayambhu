# Production runtime secrets for Swayambhu.
# Copy to `.env.prod` and fill with real values before running:
#   npm run setup:cloudflare:prod

# Required for core runtime
OPENROUTER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Required only if using Slack inbound/outbound
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=

# Required only if using Cloudflare Access-protected email relay
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
EMAIL_RELAY_SECRET=

# Required only if using Google Docs tool
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=

# Required only if using publications KB tool
ISHA_PUBLICATIONS_PASSWORD=

# Required only if using remote execution
COMPUTER_API_KEY=

# Required only if using wallet monitoring
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# Not Worker secrets. These belong on the email gateway host:
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# Optional local/operator secret — not currently pushed to the runtime worker:
# GITHUB_PAT=
